<% if line_items.any? %>
  <% line_items.each do |item| %>
    <div id="line_item_<%= item.id %>" class="order-item">
      <% if item.product.is_a?(Engine) %>
        <%# Engines are polymorphic -> engineable has photos %>
        <%= image_tag item.product.engineable.photos.first,
                      alt: item.product.title,
                      class: "bike-thumbnail" %>
        <div>
          <p><strong>Engine Ordered:</strong> <%= item.product.title %></p>
        </div>
      <% elsif item.product.is_a?(Wheel) %>
        <%# Wheels have photos directly %>
        <%= image_tag item.product.photos.first,
                      alt: item.product.name,
                      class: "wheel-thumbnail" %>
        <div>
          <p><strong>Wheel Ordered:</strong> <%= item.product.name %></p>
        </div>
      <% end %>

      <p>
        Quantity: <%= item.quantity %> |
        <strong>Total:</strong> <%= number_to_currency(item.total) %>
      </p>

      <%= button_to(
          "<i class='fa-solid fa-trash'></i>".html_safe,
          cart_remove_item_path(item.id),
          method: :post,
          form: { data: { turbo_confirm: "Are you sure?" } },
          class: "text-rd"
        ) %>
    </div>
  <% end %>
<% else %>
   <div class="empty-cart">
      <svg class="empty-cart-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 3H5L5.4 5M7 13H17L21 5H5.4M7 13L5.4 5M7 13L4.7 15.3C4.3 15.7 4.6 16.5 5.1 16.5H17M17 13V16.5M9 19.5C9.8 19.5 10.5 20.2 10.5 21S9.8 22.5 9 22.5 7.5 21.8 7.5 21 8.2 19.5 9 19.5ZM20 19.5C20.8 19.5 21.5 20.2 21.5 21S20.8 22.5 20 22.5 18.5 21.8 18.5 21 19.2 19.5 20 19.5Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <h3>Your Cart is Empty</h3>
      <p>Add some items to get started!</p>
      <%= link_to "Return To Wheels", wheels_path, class: "shop-link", data: { turbo_frame: "_top" } %>  
        <%= link_to "Return To Engines", engines_path, class: "shop-link", data: { turbo_frame: "_top" } %>       
      </div>
<% end %>
