<div id="modal" class="modal">
  <div class="modal-content">
    <%= form_with model: purchase, url: cart_checkout_path, data: { turbo_frame: "checkout_modal" } do |f| %>
      <h2>Checkout</h2>

      <h4>Customer Info</h4>
      <%= f.email_field :email, placeholder: "Email", required: true %>
      <%= f.telephone_field :phone, placeholder: "Phone", required: true %>

      <h4>Shipping Address</h4>
      <%= f.text_field :shipping_address, placeholder: "Full Shipping Address", required: true %>

      <h4>Billing Address</h4>
      <%= f.text_field :billing_address, placeholder: "Billing Address (or same)", required: true %>

      <h4>Payment Method</h4>
      <%= f.radio_button :payment_method, "card" %>
      <%= f.label :payment_method_card, "Credit/Debit Card (Visa, Mastercard, AmEx, Discover)" %><br>

      <%= f.radio_button :payment_method, "paypal" %>
      <%= f.label :payment_method_paypal, "PayPal" %><br>

      <%= f.radio_button :payment_method, "apple_pay" %>
      <%= f.label :payment_method_apple_pay, "Apple Pay" %><br>

      <%= f.radio_button :payment_method, "google_pay" %>
      <%= f.label :payment_method_google_pay, "Google Pay" %><br>
      <div class="checkout-buttons">
        <%= f.submit "Place Order", class: "btn-primary" %>
      </div>
    <% end %>

    <button class="modal-close" data-action="click->checkout#close">Close</button>
  </div>
</div>
